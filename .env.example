# =============================================================================
# PedidoLocal — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# URL de conexão com pooling (para a aplicação Next.js)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres?pgbouncer=true"

# URL de conexão direta (para migrations do Prisma)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# Autenticação
# -----------------------------------------------------------------------------
# Segredo para assinar cookies de sessão (mínimo 32 caracteres)
# Gere com: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_A_RANDOM_SECRET"

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
# URL base da aplicação (sem barra final)
APP_URL="http://localhost:3000"

# Ambiente
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Supabase API (opcional; não substitui DATABASE_URL/DIRECT_URL do Prisma)
# -----------------------------------------------------------------------------
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_JWKS_URL=""

# -----------------------------------------------------------------------------
# Realtime (Pusher — opcional em desenvolvimento)
# -----------------------------------------------------------------------------
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# -----------------------------------------------------------------------------
# Storage (Imagens)
# -----------------------------------------------------------------------------
# Provider: "local" | "vercel-blob" | "supabase" | "s3" | "r2"
STORAGE_PROVIDER="local"

# Token do provider (quando aplicável)
STORAGE_TOKEN=""

# -----------------------------------------------------------------------------
# Super Admin
# -----------------------------------------------------------------------------
# E-mail do super administrador inicial
SUPER_ADMIN_EMAIL="admin@pedidolocal.com.br"

# -----------------------------------------------------------------------------
# Seed (apenas desenvolvimento)
# -----------------------------------------------------------------------------
SEED_OWNER_EMAIL="dono@demo.com"
SEED_OWNER_PASSWORD="SenhaDemo123!"
