# Copie para .env.local no desenvolvimento Node. Nunca versione .env.local.

# Prisma local/CLI. Migrations e Studio usam DIRECT_URL, nunca Hyperdrive.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Supabase Auth. Somente URL e publishable key são públicas.
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"
SUPABASE_SECRET_KEY="sb_secret_REPLACE_ME"

APP_URL="http://localhost:3000"
APP_ENV="development"
NODE_ENV="development"

# Realtime/Pusher (opcional em desenvolvimento).
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""
# Use somente durante a janela de migração descrita em docs/order-realtime-rollout.md.
PUSHER_LEGACY_PUBLIC_CHANNELS="false"
ORDER_EVENT_PUBLISH_MODE="direct"

# Storage.
STORAGE_PROVIDER="local"
STORAGE_TOKEN=""

# Bootstrap do seed. A autorização em runtime usa apenas public.users.platformRole.
SEED_SUPER_ADMIN_EMAIL=""
SEED_SUPER_ADMIN_NAME="Administrador da plataforma"
SEED_OWNER_EMAIL="dono@demo.com"

# Defina apenas durante `pnpm db:seed`; não reutilize senhas reais.
SEED_SUPER_ADMIN_PASSWORD=""
SEED_OWNER_PASSWORD=""
SEED_TEAM_PASSWORD=""

# Playwright white-label. Use somente uma base/loja de teste dedicada.
E2E_SUPER_ADMIN_EMAIL=""
E2E_SUPER_ADMIN_PASSWORD=""
E2E_OWNER_EMAIL=""
E2E_OWNER_PASSWORD=""
E2E_TENANT_ID=""
E2E_STORE_ID=""
E2E_STORE_SLUG=""
E2E_ORDER_TRACKING_TOKEN=""
# Habilite explicitamente apenas quando a suíte puder publicar e reverter dados de teste.
E2E_ALLOW_MUTATIONS="false"

# Benchmarks de pedidos. Use somente localhost ou staging descartável.
ORDER_LOAD_BASE_URL="http://localhost:3000"
ORDER_LOAD_PATH="/dashboard/orders"
ORDER_LOAD_COOKIE=""
ORDER_LOAD_REQUESTS="200"
ORDER_LOAD_CONCURRENCY="50"
ORDER_LOAD_P95_BUDGET_MS="1000"
ORDER_LOAD_ACKNOWLEDGE_STAGING="false"
ORDER_PERF_STORE_ID=""
ORDER_PERF_SAMPLES="5"
ORDER_PERF_BUDGET_MS="750"
ORDER_PERF_ACKNOWLEDGE_STAGING="false"
